<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-gH2yIJqKdNHPEq0n4Mqa/HGKIhSkIHeL5AyhkYV8i59U5AR6csBvApHHNl/vI1Bx" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css" rel="stylesheet">
    <!-- custome css -->
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/signup.css">
    <!-- google fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;700&display=swap" rel="stylesheet">
    <title>Shortly</title>
</head>
<body>

    <!-- Navigation bar -->
<nav class="navbar navbar-expand-lg">
    <div class="container pt-lg-3">
      <a class="navbar-brand" href="/">Shortly</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarSupportedContent">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link" aria-current="page" href="#">Features</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#">Pricing</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#">Resources</a>
          </li>
        </ul>
        <div class="nav-item dropdown">
          <!-- class="nav-link dropdown-toggle d-flex align-items-center" -->
          <a
            class="nav-link"
            href="#" 
            role="button" 
            data-bs-toggle="dropdown" 
            aria-expanded="false"
          >
            <img
              src="https://mdbcdn.b-cdn.net/img/Photos/Avatars/img (32).webp"
              class="rounded-circle"
              height="40"
              alt="profile picture"
              loading="lazy"
            />
          </a>
          <ul class="dropdown-menu">
            <li>
              <form action="/logout" method="post">
                <input type="submit" class="dropdown-item" value="Logout">
              </form>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </nav>

<div class="container" style="margin-bottom: 13rem;">
    <div class="shorten">
        <form name="urlForm" action="/short" method="post" onsubmit="return validateForm()">
            <div class="input-group input-group-lg mb-1 shorten-box">
                <input id="url-input" name="urlInput"  class="form-control me-lg-2 " placeholder="Shorten a link here..">
                <button id="input-btn" class="btn-style btn-shorten btn-hover" value="submit"  type="submit">Shorten it!</button>
              </div>
              <span class="input-check"></span>
        </form>
    </div>
    <% links.forEach((link, index)=>{ %> 
      <div class="link-box mx-lg-5">
          <p class="url"><%= link.orginalUrl %></p>
          <span class="longline"></span>
          <p id="url<%= index %>" class="shorten-url push">localhost:3000/<%= link.urlId %></p>
          <button id="btn-copy-<%= index %>" onclick="copyToClipbourd('<%= index %>')" class="btn-copy btn-style btn-hover">copy</button>
          <form action="/delete" method="post">
            <input type="hidden" name="linkId" value="<%= link.idString %>">
            <button type="submit" class="btn btn-dark btn-delete">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-trash" viewBox="0 0 16 16">
              <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
              <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
              </svg>
            </button>
          </form>
        </div>
    <% }); %> 
</div>
<div class="container px-lg-5 ">
    
</div>

<%- include('partials/footer') %> 